{
  "defaultHomeserver": 0,
  "homeserverList": ["sayance.localhost"],
  "allowCustomHomeservers": true,
  "featuresEnabled": {
    "spacesEnabled": true,
    "voipEnabled": true,
    "threadsEnabled": true,
    "elementCallEnabled": true
  },
  "hashRouter": {
    "enabled": true,
    "basename": "/"
  },
  "branding": {
    "name": "Sayance",
    "logo": "/logo.svg",
    "favicon": "/favicon.ico"
  },
  "elementCall": {
    "url": "https://call.sayance.localhost",
    "participantLimit": 8,
    "brand": "Sayance Call"
  },
  "allowedWidgets": ["https://call.sayance.localhost", "https://app.sayance.localhost", "http://localhost:8080"],
  "experimentalFeatures": {
    "msc4143": true,
    "msc4140": true,
    "msc4222": true,
    "msc3266": true
  },
  "developmentMode": true,
  "themes": [
    {
      "name": "Silver",
      "id": "silver"
    }
  ],
  "defaultTheme": "silver"
}
